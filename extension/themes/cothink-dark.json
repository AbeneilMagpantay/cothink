    "inputValidation.errorBackground": "#3a1d1d",
    "inputValidation.errorBorder": "#f48771",
    "inputValidation.warningBackground": "#3a2d1d",
    "inputValidation.warningBorder": "#cca700",
    "inputValidation.infoBackground": "#1d2d3a",
    "inputValidation.infoBorder": "#75beff",

    "dropdown.background": "#1a1d23",
    "dropdown.foreground": "#d8dee9",
    "dropdown.border": "#2a2d33",

    "button.background": "#3a9d8c",
