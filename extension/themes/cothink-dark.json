    "statusBarItem.warningBackground": "#cca700",
    "statusBarItem.warningForeground": "#11151a",
    "statusBarItem.errorBackground": "#f48771",
    "statusBarItem.errorForeground": "#ffffff",

    "titleBar.activeBackground": "#0d1014",
    "titleBar.activeForeground": "#d8dee9",
    "titleBar.inactiveBackground": "#0a0c10",
