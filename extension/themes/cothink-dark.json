    "button.hoverBackground": "#7adcc8",
    "button.secondaryBackground": "#2a2d33",
    "button.secondaryForeground": "#d8dee9",
    "button.secondaryHoverBackground": "#3a4252",

    "badge.background": "#a464a0",
    "badge.foreground": "#ffffff",

    "panel.background": "#0d1014",
    "panel.border": "#1a1d23",
    "panelTitle.activeForeground": "#7adcc8",
    "panelTitle.inactiveForeground": "#6a7388",
    "panelTitle.activeBorder": "#7adcc8",

    "scrollbar.shadow": "#00000000",
    "scrollbarSlider.background": "#2a2d3380",
    "scrollbarSlider.hoverBackground": "#3a4252",
    "scrollbarSlider.activeBackground": "#7adcc8",

    "terminal.background": "#11151a",
    "terminal.foreground": "#d8dee9",
    "terminalCursor.foreground": "#d7a8d1",
    "terminal.ansiBlack": "#11151a",
    "terminal.ansiRed": "#f48771",
    "terminal.ansiGreen": "#7adcc8",
    "terminal.ansiYellow": "#cca700",
    "terminal.ansiBlue": "#75beff",
    "terminal.ansiMagenta": "#d7a8d1",
    "terminal.ansiCyan": "#7adcc8",
    "terminal.ansiWhite": "#d8dee9",
    "terminal.ansiBrightBlack": "#5a6275",
    "terminal.ansiBrightRed": "#f48771",
    "terminal.ansiBrightGreen": "#7adcc8",
    "terminal.ansiBrightYellow": "#cca700",
    "terminal.ansiBrightBlue": "#75beff",
    "terminal.ansiBrightMagenta": "#d7a8d1",
    "terminal.ansiBrightCyan": "#7adcc8",
    "terminal.ansiBrightWhite": "#ffffff",

    "diffEditor.insertedTextBackground": "#3a9d8c20",
    "diffEditor.removedTextBackground": "#f4877120",
    "diffEditor.insertedLineBackground": "#3a9d8c15",
    "diffEditor.removedLineBackground": "#f4877115",

    "gitDecoration.modifiedResourceForeground": "#7adcc8",
    "gitDecoration.deletedResourceForeground": "#f48771",
    "gitDecoration.untrackedResourceForeground": "#a5d6a7",
    "gitDecoration.ignoredResourceForeground": "#5a6275",
    "gitDecoration.conflictingResourceForeground": "#cca700",
    "gitDecoration.submoduleResourceForeground": "#d7a8d1",

    "notificationCenter.border": "#1a1d23",
    "notificationCenterHeader.background": "#11151a",
    "notificationCenterHeader.foreground": "#d8dee9",
    "notifications.background": "#11151a",
    "notifications.foreground": "#d8dee9",
    "notifications.border": "#1a1d23",
    "notificationLink.foreground": "#7adcc8",
    "notificationsErrorIcon.foreground": "#f48771",
    "notificationsWarningIcon.foreground": "#cca700",
    "notificationsInfoIcon.foreground": "#75beff",

    "pickerGroup.foreground": "#7adcc8",
    "pickerGroup.border": "#1a1d23",
    "quickInput.background": "#11151a",
    "quickInput.foreground": "#d8dee9",
    "quickInputTitle.background": "#0d1014",
    "quickInputList.focusBackground": "#3a9d8c30",
    "quickInputList.focusForeground": "#d8dee9",
    "quickInputList.focusIconForeground": "#7adcc8",

    "breadcrumb.foreground": "#9aa3b5",
    "breadcrumb.background": "#11151a",
    "breadcrumb.focusForeground": "#7adcc8",
    "breadcrumb.activeSelectionForeground": "#7adcc8",
    "breadcrumbPicker.background": "#11151a",

    "minimap.findMatchHighlight": "#a464a0",
    "minimap.selectionHighlight": "#7adcc8",
    "minimap.errorHighlight": "#f48771",
    "minimap.warningHighlight": "#cca700",
    "minimapGutter.modifiedBackground": "#7adcc8",
    "minimapGutter.addedBackground": "#3a9d8c",
    "minimapGutter.deletedBackground": "#f48771",

    "widget.shadow": "#00000050",
    "editorWidget.background": "#11151a",
    "editorWidget.foreground": "#d8dee9",
    "editorWidget.border": "#1a1d23",
    "editorSuggestWidget.background": "#11151a",
    "editorSuggestWidget.border": "#1a1d23",
    "editorSuggestWidget.foreground": "#d8dee9",
    "editorSuggestWidget.selectedBackground": "#3a9d8c30",
    "editorSuggestWidget.highlightForeground": "#7adcc8",
    "editorHoverWidget.background": "#11151a",
    "editorHoverWidget.border": "#1a1d23",
    "editorHoverWidget.foreground": "#d8dee9",

    "extensionButton.prominentBackground": "#3a9d8c",
    "extensionButton.prominentHoverBackground": "#7adcc8",
    "extensionBadge.remoteBackground": "#a464a0",
    "extensionBadge.remoteForeground": "#ffffff"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": {
        "foreground": "#5a6275",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["constant", "constant.character", "constant.other"],
      "settings": {
        "foreground": "#ffb74d"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#ffb74d"
      }
    },
    {
      "scope": ["constant.language"],
      "settings": {
        "foreground": "#d7a8d1"
      }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#7adcc8"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#7adcc8"
      }
    },
    {
      "scope": ["entity.name.class", "entity.name.type", "support.class", "support.type"],
      "settings": {
        "foreground": "#7adcc8"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#d7a8d1"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#9cdcfe"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#3a9d8c",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "keyword.control"],
      "settings": {
        "foreground": "#d7a8d1"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#9aa3b5"
      }
    },
    {
      "scope": ["keyword.other.import", "keyword.other.from", "keyword.other.as"],
      "settings": {
        "foreground": "#d7a8d1"
      }
    },
    {
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#d7a8d1"
      }
    },
    {
      "scope": ["string"],
      "settings": {
        "foreground": "#a5d6a7"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#ffb74d"
      }
    },
    {
      "scope": ["string.template", "punctuation.definition.template-expression"],
      "settings": {
        "foreground": "#7adcc8"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#d8dee9"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#d8dee9"
      }
    },
    {
      "scope": ["variable.language", "variable.language.this", "variable.language.self"],
      "settings": {
        "foreground": "#d7a8d1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.constant", "support.variable"],
      "settings": {
        "foreground": "#9cdcfe"
      }
    },
    {
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#9aa3b5"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#d7a8d1"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#f48771"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#cca700",
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": ["markup.heading", "markup.heading entity.name"],
      "settings": {
        "foreground": "#7adcc8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#d8dee9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#d8dee9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.underline"],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#3a9d8c"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#f48771"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#cca700"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#9aa3b5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.link"],
      "settings": {
        "foreground": "#7adcc8",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.fenced_code", "markup.inline.raw"],
      "settings": {
        "foreground": "#a5d6a7"
      }
    }
  ]
}
