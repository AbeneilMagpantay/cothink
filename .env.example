# Claude calls use claude-agent-sdk, which authenticates via your Claude Code
# subscription (the same login as `claude` CLI). No ANTHROPIC_API_KEY needed —
# do NOT set one here, or it will route through pay-per-token API billing.

GEMINI_API_KEY=...

# Optional model overrides. Defaults are cost-conscious for v0.
COTHINK_CLAUDE_MODEL=claude-sonnet-4-6
COTHINK_GEMINI_MODEL=gemini-3.1-pro-preview
COTHINK_GEMINI_FLASH_MODEL=gemini-3.1-flash-lite
